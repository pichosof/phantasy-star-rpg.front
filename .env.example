REACT_APP_BASE_URL=
REACT_APP_ASSETS_BUCKET=https://lightence-assets.s3.amazonaws.com
REACT_APP_API_BASE_URL=http://localhost:3010
REACT_APP_UPLOAD_MAX_MB=30
# Must match CLIENT_SECRET in the backend .env
REACT_APP_CLIENT_SECRET=generate-a-strong-random-secret-here
# Set to true to simulate production behaviour in dev (e.g. auto-logout on 401)
REACT_APP_SIMULATE_PROD=false

# more info https://create-react-app.dev/docs/advanced-configuration
ESLINT_NO_DEV_ERRORS=
TSC_COMPILE_ON_ERROR=
