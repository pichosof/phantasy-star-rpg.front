# Public base path for the SPA (leave empty for root)
VITE_BASE_URL=
# Optional CDN/bucket for remote assets (images, etc.)
VITE_ASSETS_BUCKET=
# Backend API base URL (in dev usually http://localhost:3010)
VITE_API_BASE_URL=http://localhost:3010
# Max upload size in MB — must match MAX_UPLOAD_MB in the backend .env
VITE_UPLOAD_MAX_MB=30
# Shared secret between frontend and backend — must match CLIENT_SECRET in the backend .env
VITE_CLIENT_SECRET=generate-a-strong-random-secret-here
# Set to true to simulate production behaviour in dev (e.g. auto-logout on 401)
VITE_SIMULATE_PROD=false
